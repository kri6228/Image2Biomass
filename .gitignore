# ============================================================
# Image2Biomass - Git Ignore
# ============================================================


# ------------------------------------------------------------
# Python cache and compiled files
# ------------------------------------------------------------

__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd


# ------------------------------------------------------------
# Python environments
# ------------------------------------------------------------

venv/
.venv/
env/
ENV/
conda-env/
.python-version


# ------------------------------------------------------------
# Jupyter Notebook
# ------------------------------------------------------------

.ipynb_checkpoints/
*/.ipynb_checkpoints/
notebooks/catboost_info/

# ------------------------------------------------------------
# IDE and editor files
# ------------------------------------------------------------

.vscode/
.idea/
*.code-workspace


# ------------------------------------------------------------
# Operating system files
# ------------------------------------------------------------

.DS_Store
Thumbs.db
desktop.ini


# ------------------------------------------------------------
# Environment variables and secrets
# ------------------------------------------------------------

.env
.env.*
!.env.example

.streamlit/secrets.toml


# ------------------------------------------------------------
# Raw datasets
#
# Do not upload Kaggle / CSIRO image datasets to GitHub.
# ------------------------------------------------------------

data/raw/


# ------------------------------------------------------------
# Processed datasets and generated feature artifacts
# ------------------------------------------------------------

data/processed/


# ------------------------------------------------------------
# Cached CNN and metadata features
# ------------------------------------------------------------

**/cached_features/


# ------------------------------------------------------------
# Generated fold data
# ------------------------------------------------------------

**/folds/


# ------------------------------------------------------------
# Generated feature tables
# ------------------------------------------------------------

**/feature_tables/


# ------------------------------------------------------------
# Experimental and training model artifacts
# ------------------------------------------------------------

models/

*.pkl
*.pickle
*.keras
*.h5
*.hdf5
*.ckpt


# ------------------------------------------------------------
# Production inference artifacts
#
# These artifacts are required by src/inference.py and the
# Streamlit application.
# ------------------------------------------------------------

!production_artifacts/
!production_artifacts/models/
!production_artifacts/models/*.joblib
!production_artifacts/metadata_preprocessors/
!production_artifacts/metadata_preprocessors/*.joblib
!production_artifacts/configuration/
!production_artifacts/configuration/*.json

# ------------------------------------------------------------
# NumPy generated artifacts
# ------------------------------------------------------------

*.npy
*.npz


# ------------------------------------------------------------
# Generated predictions
# ------------------------------------------------------------

predictions/


# ------------------------------------------------------------
# Generated outputs
# ------------------------------------------------------------

outputs/


# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------

logs/
*.log


# ------------------------------------------------------------
# Temporary files
# ------------------------------------------------------------

tmp/
temp/
*.tmp
*.temp
*.bak
*.swp
*.swo


# ------------------------------------------------------------
# Test / coverage artifacts
# ------------------------------------------------------------

.pytest_cache/
.coverage
htmlcov/


# ------------------------------------------------------------
# Python packaging artifacts
# ------------------------------------------------------------

build/
dist/
*.egg-info/
.eggs/


# ------------------------------------------------------------
# Streamlit cache
# ------------------------------------------------------------

.streamlit/cache/


# ------------------------------------------------------------
# Local profiling artifacts
# ------------------------------------------------------------

*.prof
*.lprof


# ------------------------------------------------------------
# Large archives
# ------------------------------------------------------------

*.zip
*.rar
*.7z
*.tar
*.tar.gz
*.gz